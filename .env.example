# Production Docker Compose configuration.
#   cp .env.example .env && docker compose up -d --build
# .env is gitignored — never commit real secrets.

# --- Database (Neon or any Postgres) ---
# Owner role — migrations only. sslmode=verify-full is required in production.
DATABASE_URL=postgresql://owner:password@host/db?sslmode=verify-full
# Least-privilege runtime role (oraos_api). Must DIFFER from DATABASE_URL or the
# API refuses to boot. Generate with:
#   DATABASE_URL="<owner url>" pnpm --filter @oraos/api db:setup-app-role -- --print
DATABASE_URL_APP=postgresql://oraos_api:password@host/db?sslmode=verify-full

# --- Auth ---
# >=32 chars, unique per environment: openssl rand -base64 48
JWT_SECRET=

# --- URLs (all must be https in production) ---
# Comma-separated browser origins allowed by CORS.
CORS_ORIGINS=https://app.example.com
# Web base URL — builds invite and password-reset links.
WEB_URL=https://app.example.com
# Public API URL, baked into the web bundle AT BUILD TIME (and into the CSP).
NEXT_PUBLIC_API_URL=https://api.example.com/api/v1

# --- Email (optional; leave blank to log instead of send) ---
RESEND_API_KEY=
MAIL_FROM=OraOS <noreply@example.com>

# --- Ops (optional) ---
APP_VERSION=
LOG_LEVEL=info
# Published host ports (container ports are fixed at 3001/3000).
API_PORT=3001
WEB_PORT=3000
