// OraOS schema — foundation + orders (Step 4).
// Later phases add their own tables by migration. See docs/BLUEPRINT.md §5.
//
// Conventions:
//   - UUIDv7 ids: time-ordered (index locality) and client-generatable, which
//     offline POS requires — a server-assigned id cannot exist offline.
//   - Money is integer minor units (paise). Never a float.
//   - Tenant-scoped tables carry restaurant_id and are protected by RLS.
//     Global tables are marked below. See prisma/sql/rls.sql.

generator client {
  provider = "prisma-client"
  // Inside src/ so `nest build` compiles the generated client into dist.
  output = "../src/generated/prisma"

  // NestJS compiles to CommonJS; Prisma 7 emits ESM by default and the two do
  // not mix at runtime. Extensionless imports resolve under both ts-node and
  // compiled CJS — a ".js" extension breaks ts-node against ".ts" sources.
  moduleFormat        = "cjs"
  runtime             = "nodejs"
  importFileExtension = ""
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Identity & tenancy
// ---------------------------------------------------------------------------

/// Tenant root.
model Restaurant {
  id        String   @id @default(uuid(7)) @db.Uuid
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branches    Branch[]
  memberships Membership[]
  orders      Order[]
  auditLogs   AuditLog[]
  staffInvites StaffInvite[]

  @@map("restaurants")
}

/// Every restaurant has at least one, even single-location ones. Retrofitting
/// branches later would mean rewriting every tenant-scoped query.
model Branch {
  id           String   @id @default(uuid(7)) @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  name         String
  address      String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  restaurant  Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  memberships Membership[]
  orders      Order[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@map("branches")
}

/// GLOBAL — not tenant-scoped. One human, one login, possibly many restaurants.
/// Email is stored lowercase; a CHECK constraint enforces it, which makes the
/// unique index effectively case-insensitive without the citext extension.
model User {
  id           String   @id @default(uuid(7)) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  isActive     Boolean  @default(true) @map("is_active")
  /// Session epoch, set by "sign out everywhere". A refresh-token family that
  /// began before this instant can never be used again — which is what stops a
  /// refresh already in flight from minting a session that outlives the
  /// revocation. NULL means it has never been used.
  sessionsValidFrom DateTime? @map("sessions_valid_from")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  memberships   Membership[]
  refreshTokens RefreshToken[]

  @@map("users")
}

enum SecurityEventType {
  REGISTERED
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  REFRESH_ROTATED
  REFRESH_REUSE_DETECTED
  RESTAURANT_SELECTED

  @@map("security_event_type")
}

/// GLOBAL — identity-scoped, not tenant-scoped. Deliberately a separate table
/// from audit_logs rather than making audit_logs.restaurant_id nullable.
///
/// The two answer different questions and have different owners:
///   security_events — "what happened to this identity?" Login, logout, token
///                     theft. Happens before a tenant context can exist, so it
///                     cannot live in a tenant-scoped table.
///   audit_logs      — "what did someone do inside this restaurant?" Always
///                     has a tenant.
///
/// The alternative (nullable restaurant_id on audit_logs) would have punched a
/// hole in the RLS policy that is the system's primary security boundary. A
/// second table is cheaper than a weakened boundary.
///
/// userId is nullable: a failed login for an unknown email has no user, and
/// that row is exactly the one worth keeping when investigating credential
/// stuffing. `email` records what was attempted.
///
/// Deliberately NO foreign key to users — same pattern as audit_logs.userId and
/// order_items.productId, for the same reason: the record must outlive what it
/// refers to.
///
/// This was learned the hard way. The first version used
/// `onDelete: SetNull`, which made deleting a user issue an UPDATE against
/// security_events — refused by the append-only trigger, rendering users
/// permanently undeletable. Referential integrity and an immutable history are
/// mutually exclusive here, and history wins: a deleted account's login trail
/// is exactly what an investigation needs.
model SecurityEvent {
  id        String            @id @default(uuid(7)) @db.Uuid
  userId    String?           @map("user_id") @db.Uuid
  email     String?
  type      SecurityEventType
  ipAddress String?           @map("ip_address")
  userAgent String?           @map("user_agent")
  metadata  Json?
  createdAt DateTime          @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@index([type, createdAt])
  @@map("security_events")
}

/// GLOBAL — keyed by user, not tenant, so no RLS (same rationale as users).
///
/// Refresh tokens are opaque random strings, never JWTs: they must be
/// revocable, and a stateless token cannot be revoked. Only the SHA-256 hash
/// is stored — a database leak must not yield usable tokens. SHA-256 rather
/// than bcrypt is deliberate: the token is already 256 bits of entropy, so
/// there is nothing to brute-force and no reason to pay bcrypt's cost on every
/// refresh.
///
/// familyId enables reuse detection. Rotation means each refresh mints a new
/// token and revokes the old one; if an already-used token is presented again,
/// it was stolen (or cloned), so the entire family is revoked at once.
model RefreshToken {
  id           String    @id @default(uuid(7)) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  tokenHash    String    @unique @map("token_hash")
  familyId     String    @map("family_id") @db.Uuid
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  replacedById String?   @map("replaced_by_id") @db.Uuid
  userAgent    String?   @map("user_agent")
  ipAddress    String?   @map("ip_address")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

/// GLOBAL reference data. System roles, seeded. Per-tenant custom roles would
/// add a nullable restaurant_id here — not needed yet.
model Role {
  id   String @id @default(uuid(7)) @db.Uuid
  key  String @unique
  name String

  permissions  RolePermission[]
  memberships  Membership[]
  staffInvites StaffInvite[]

  @@map("roles")
}

/// GLOBAL reference data. Permissions are checked by key ("order.refund"),
/// never by role name — role names change, permissions do not.
model Permission {
  id          String @id @default(uuid(7)) @db.Uuid
  key         String @unique
  description String

  roles RolePermission[]

  @@map("permissions")
}

/// GLOBAL reference data.
model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

/// user <-> restaurant <-> role. This is why role is not a column on User: the
/// same person can be an owner at one restaurant and a cashier at another.
/// branchId null means "all branches of this restaurant".
model Membership {
  id           String   @id @default(uuid(7)) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  branchId     String?  @map("branch_id") @db.Uuid
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  role       Role       @relation(fields: [roleId], references: [id])
  branch     Branch?    @relation(fields: [branchId], references: [id], onDelete: SetNull)

  attendance AttendanceEvent[]

  @@unique([userId, restaurantId])
  @@index([restaurantId])
  @@index([userId])
  @@map("memberships")
}

/// Append-only, enforced by trigger rather than convention.
/// The likeliest attacker is a logged-in employee; this is the record that
/// survives them.
model AuditLog {
  id           String   @id @default(uuid(7)) @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  action       String
  entityType   String   @map("entity_type")
  entityId     String?  @map("entity_id") @db.Uuid
  metadata     Json?
  ipAddress    String?  @map("ip_address")
  createdAt    DateTime @default(now()) @map("created_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, createdAt])
  @@index([restaurantId, entityType, entityId])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Catalogue
// ---------------------------------------------------------------------------

/// Tenant-scoped. Optional grouping for the POS grid.
model Category {
  id           String   @id @default(uuid(7)) @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  name         String
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  products Product[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@map("categories")
}

/// Tenant-scoped menu item.
///
/// priceMinor is the CURRENT price. It is deliberately NOT what an order line
/// reads back: order_items snapshot the price at sale time, so repricing a
/// product tomorrow cannot rewrite last month's revenue.
///
/// Products are deactivated, never deleted — order_items.productId points here
/// with no FK precisely so history survives, and a hard delete would leave the
/// menu inconsistent with its own reports.
model Product {
  id           String   @id @default(uuid(7)) @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  categoryId   String?  @map("category_id") @db.Uuid
  name         String
  priceMinor   Int      @map("price_minor")
  /// Basis points: 500 = 5%, the GST rate on restaurant food in India.
  taxRateBp    Int      @default(500) @map("tax_rate_bp")
  isActive     Boolean  @default(true) @map("is_active")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  category    Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  recipeItems RecipeItem[]

  @@unique([restaurantId, name])
  @@index([restaurantId, isActive])
  @@map("products")
}

// ---------------------------------------------------------------------------
// Marketing
// ---------------------------------------------------------------------------

enum CouponType {
  /// A percentage off the subtotal, in basis points (1000 = 10%).
  PERCENT
  /// A flat amount off, in paise.
  FIXED

  @@map("coupon_type")
}

/// A discount code. The RULES are deterministic and enforced server-side — a
/// coupon never lets a client choose its own discount, and every redemption is
/// recomputed from the coupon and the order, never trusted from input.
model Coupon {
  id           String     @id @default(uuid(7)) @db.Uuid
  restaurantId String     @map("restaurant_id") @db.Uuid
  /// Uppercased, unique per tenant. Two restaurants may both have "DIWALI10".
  code         String
  type         CouponType
  /// PERCENT only, basis points (1000 = 10%). Null for FIXED.
  percentBp    Int?       @map("percent_bp")
  /// FIXED only, paise. Null for PERCENT.
  amountMinor  Int?       @map("amount_minor")
  /// Optional cap on a PERCENT discount, paise.
  maxDiscountMinor Int?   @map("max_discount_minor")
  /// The order subtotal must reach this for the coupon to apply. 0 = no minimum.
  minSubtotalMinor Int    @default(0) @map("min_subtotal_minor")
  /// Total times this code may be redeemed across the restaurant. Null = unlimited.
  maxRedemptions Int?     @map("max_redemptions")
  validFrom    DateTime?  @map("valid_from")
  validUntil   DateTime?  @map("valid_until")
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  redemptions CouponRedemption[]

  @@unique([restaurantId, code])
  @@index([restaurantId, isActive])
  @@map("coupons")
}

/// Append-only record of a coupon being used on an order. This is money, so it
/// is immutable like every other financial record: the discount that was given
/// cannot be quietly rewritten after the fact.
model CouponRedemption {
  id            String   @id @default(uuid(7)) @db.Uuid
  restaurantId  String   @map("restaurant_id") @db.Uuid
  couponId      String   @map("coupon_id") @db.Uuid
  /// The order it was applied to. One coupon per order (unique).
  orderId       String   @unique @map("order_id") @db.Uuid
  /// The discount actually granted, recomputed server-side. Paise.
  discountMinor Int      @map("discount_minor")
  createdAt     DateTime @default(now()) @map("created_at")

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Restrict)

  @@index([restaurantId, couponId])
  @@map("coupon_redemptions")
}

// ---------------------------------------------------------------------------
// Staff
// ---------------------------------------------------------------------------

/// A pending invitation to join a restaurant.
///
/// Staff join by accepting a link, NOT by an owner typing a password for them.
/// An owner who knows a cashier's password destroys attribution: every audit
/// entry and every void becomes deniable ("the owner could have done that").
/// The invitee sets their own password and nobody else ever knows it.
///
/// The token is stored only as a SHA-256 hash, same reasoning as refresh
/// tokens: a database leak must not hand over working invitations. There is no
/// email dependency — the link is shared however the restaurant already talks
/// to its staff, which in practice is WhatsApp.
model StaffInvite {
  id           String    @id @default(uuid(7)) @db.Uuid
  restaurantId String    @map("restaurant_id") @db.Uuid
  email        String
  roleId       String    @map("role_id") @db.Uuid
  tokenHash    String    @unique @map("token_hash")
  expiresAt    DateTime  @map("expires_at")
  acceptedAt   DateTime? @map("accepted_at")
  revokedAt    DateTime? @map("revoked_at")
  invitedBy    String?   @map("invited_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  role       Role       @relation(fields: [roleId], references: [id])

  @@index([restaurantId, acceptedAt])
  @@index([expiresAt])
  @@map("staff_invites")
}

enum AttendanceEventType {
  CLOCK_IN
  CLOCK_OUT

  @@map("attendance_event_type")
}

/// The attendance ledger. Append-only, like every other history in this system.
///
/// There is deliberately NO `isClockedIn` flag or `currentShift` row. Whether
/// someone is on shift is derived from their latest event; hours worked are
/// derived by pairing events. A mutable flag would drift the first time a
/// clock-out was missed, and it would erase the evidence of when.
///
/// This is timekeeping, which means it is pay. It gets the same immutability as
/// money: a mistake is corrected by appending, never by editing.
model AttendanceEvent {
  id           String              @id @default(uuid(7)) @db.Uuid
  restaurantId String              @map("restaurant_id") @db.Uuid
  membershipId String              @map("membership_id") @db.Uuid
  type         AttendanceEventType
  /// When it happened. Separate from createdAt so a manager correcting a
  /// forgotten clock-out can record the real time while the row still shows
  /// when the correction was actually made.
  at           DateTime
  /// Null when someone clocks themselves in; set when a manager does it for
  /// them. The difference matters in a dispute.
  recordedBy   String?             @map("recorded_by") @db.Uuid
  note         String?
  createdAt    DateTime            @default(now()) @map("created_at")

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([restaurantId, membershipId, at])
  @@map("attendance_events")
}

// ---------------------------------------------------------------------------
// Inventory
// ---------------------------------------------------------------------------

/// All stock is stored as an INTEGER count of the smallest unit — grams, not
/// kilograms; millilitres, not litres. Same discipline as money: 0.1 + 0.2 is
/// not 0.3 in binary floating point, and a drifting stock level is a drifting
/// food cost.
enum StockUnit {
  GRAM
  MILLILITRE
  PIECE

  @@map("stock_unit")
}

enum StockMovementType {
  /// Stock arriving. Positive.
  PURCHASE
  /// Sold through a recipe. Negative, written automatically when an order is placed.
  CONSUMPTION
  /// Spoiled, dropped, burnt. Negative. Kept distinct from CONSUMPTION because
  /// the difference between "sold" and "wasted" is the whole point of tracking.
  WASTE
  /// A stock count correcting reality. Signed.
  ADJUSTMENT

  @@map("stock_movement_type")
}

model Ingredient {
  id           String    @id @default(uuid(7)) @db.Uuid
  restaurantId String    @map("restaurant_id") @db.Uuid
  name         String
  unit         StockUnit
  /// Below this, the ingredient is flagged low. Null means "do not track".
  reorderLevel Int?      @map("reorder_level")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  movements   StockMovement[]
  recipeItems RecipeItem[]

  @@unique([restaurantId, name])
  @@index([restaurantId, isActive])
  @@map("ingredients")
}

/// The stock ledger. Append-only, enforced by trigger.
///
/// There is deliberately NO `quantity` column on Ingredient. Current stock is
/// SUM(quantity) over this table.
///
/// A mutable counter would be a lie the moment two things touched it at once,
/// and it would throw away the only question an owner actually asks: not "how
/// much cheese is there" but "where did the cheese go". A ledger answers both;
/// a counter answers neither honestly. It also makes concurrent depletion
/// correct for free — two simultaneous orders each append a row rather than
/// racing to overwrite the same number.
///
/// quantity is signed: PURCHASE is positive, CONSUMPTION and WASTE negative.
model StockMovement {
  id           String            @id @default(uuid(7)) @db.Uuid
  restaurantId String            @map("restaurant_id") @db.Uuid
  ingredientId String            @map("ingredient_id") @db.Uuid
  type         StockMovementType
  /// Signed, in the ingredient's base unit.
  quantity     Int
  /// Set on CONSUMPTION so a depletion can be traced back to the sale that
  /// caused it. No FK: the movement must outlive any order tidy-up, same
  /// reasoning as order_items.productId.
  orderId      String?           @map("order_id") @db.Uuid
  note         String?
  actorUserId  String?           @map("actor_user_id") @db.Uuid
  createdAt    DateTime          @default(now()) @map("created_at")

  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  @@index([restaurantId, ingredientId, createdAt])
  @@index([orderId])
  @@map("stock_movements")
}

/// What one unit of a product consumes.
///
/// No separate Recipe entity: a product's recipe IS its list of items. An empty
/// list means the product does not deplete anything, which is a legitimate
/// state (a bottled drink bought and sold as-is).
model RecipeItem {
  id           String   @id @default(uuid(7)) @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  productId    String   @map("product_id") @db.Uuid
  ingredientId String   @map("ingredient_id") @db.Uuid
  /// Per ONE unit sold, in the ingredient's base unit.
  quantity     Int
  createdAt    DateTime @default(now()) @map("created_at")

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  @@unique([productId, ingredientId])
  @@index([restaurantId])
  @@map("recipe_items")
}

// ---------------------------------------------------------------------------
// Customers
// ---------------------------------------------------------------------------

/// Tenant-scoped, and this table is PII: a real person's name, phone and
/// birthday. RLS is the boundary, as everywhere, but the stakes are higher here
/// than for a menu item — a leak is a privacy breach, not a lost recipe.
///
/// phone is unique PER TENANT, never globally. The same person eats at two
/// restaurants; each keeps its own record and neither may see the other's. A
/// global unique index would both break that and leak, via conflict errors,
/// that a number is known to some other restaurant.
///
/// Deliberately NO cached stats (visits, totalSpent). They are derived from
/// orders on read. The blueprint calls for materialising them, and it is right
/// at a million orders — but caching a number now buys a staleness bug and
/// saves nothing. See BACKLOG.
model Customer {
  id           String    @id @default(uuid(7)) @db.Uuid
  restaurantId String    @map("restaurant_id") @db.Uuid
  name         String
  /// Digits only, normalised on write, so lookup is exact rather than fuzzy.
  phone        String
  email        String?
  /// Date only — a birthday has no timezone, and storing it as an instant
  /// makes it drift across one.
  birthday     DateTime? @db.Date
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  orders Order[]

  @@unique([restaurantId, phone])
  @@index([restaurantId, name])
  @@map("customers")
}

// ---------------------------------------------------------------------------
// Orders — the money model
// ---------------------------------------------------------------------------

enum OrderStatus {
  DRAFT
  PLACED
  PREPARING
  READY
  COMPLETED
  CANCELLED
  VOIDED

  @@map("order_status")
}

enum OrderEventType {
  CREATED
  STATUS_CHANGED
  ITEM_ADDED
  ITEM_REMOVED
  PAYMENT_RECORDED
  NOTE_ADDED

  @@map("order_event_type")
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  WALLET
  OTHER

  @@map("payment_method")
}

enum PaymentStatus {
  PENDING
  CAPTURED
  FAILED

  @@map("payment_status")
}

/// Totals are DB-enforced: a CHECK asserts total = subtotal - discount + tax.
/// Arithmetic bugs fail at write time instead of surfacing in a month-end report.
model Order {
  id            String      @id @default(uuid(7)) @db.Uuid
  restaurantId  String      @map("restaurant_id") @db.Uuid
  branchId      String      @map("branch_id") @db.Uuid
  /// Nullable and always will be: most restaurant orders are anonymous
  /// walk-ins. Restrict on delete — a customer with order history cannot be
  /// erased without deciding what happens to the money.
  customerId    String?     @map("customer_id") @db.Uuid
  orderNumber   Int         @map("order_number")
  status        OrderStatus @default(DRAFT)
  subtotalMinor Int         @map("subtotal_minor")
  discountMinor Int         @default(0) @map("discount_minor")
  taxMinor      Int         @map("tax_minor")
  totalMinor    Int         @map("total_minor")
  currency      String      @default("INR") @db.Char(3)
  notes         String?
  /// Supplied by the client so a retry cannot create a second sale. Lives on
  /// the ORDER, not just the payment: an order without a payment method used
  /// to store no key at all, so a double-tapped Charge produced two orders.
  /// Unique per tenant; NULLs do not collide, so orders sent without a key are
  /// unaffected.
  idempotencyKey String?    @map("idempotency_key")
  placedAt      DateTime?   @map("placed_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  restaurant Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  branch     Branch       @relation(fields: [branchId], references: [id])
  customer   Customer?    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items      OrderItem[]
  events     OrderEvent[]
  payments   Payment[]

  @@unique([restaurantId, orderNumber])
  @@unique([restaurantId, idempotencyKey])
  @@index([restaurantId, createdAt])
  @@index([restaurantId, status])
  @@index([customerId])
  @@map("orders")
}

/// Price and name are snapshotted at sale time. productId intentionally has no
/// foreign key yet — the catalogue arrives in the POS phase — and stays
/// nullable so deleting a product can never destroy a past receipt.
model OrderItem {
  id             String   @id @default(uuid(7)) @db.Uuid
  restaurantId   String   @map("restaurant_id") @db.Uuid
  orderId        String   @map("order_id") @db.Uuid
  productId      String?  @map("product_id") @db.Uuid
  nameSnapshot   String   @map("name_snapshot")
  unitPriceMinor Int      @map("unit_price_minor")
  quantity       Int
  lineTotalMinor Int      @map("line_total_minor")
  taxRateBp      Int      @map("tax_rate_bp")
  taxMinor       Int      @map("tax_minor")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([restaurantId])
  @@map("order_items")
}

/// Append-only state log. The order timeline UI reads this, and it is the
/// evidence trail in a dispute. Enforced by trigger.
model OrderEvent {
  id           String         @id @default(uuid(7)) @db.Uuid
  restaurantId String         @map("restaurant_id") @db.Uuid
  orderId      String         @map("order_id") @db.Uuid
  type         OrderEventType
  fromStatus   OrderStatus?   @map("from_status")
  toStatus     OrderStatus?   @map("to_status")
  actorUserId  String?        @map("actor_user_id") @db.Uuid
  metadata     Json?
  createdAt    DateTime       @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@index([restaurantId, createdAt])
  @@map("order_events")
}

/// A split payment is N rows against one order.
/// idempotencyKey is unique per tenant so an offline sync retry cannot
/// double-record a payment.
model Payment {
  id             String        @id @default(uuid(7)) @db.Uuid
  restaurantId   String        @map("restaurant_id") @db.Uuid
  orderId        String        @map("order_id") @db.Uuid
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  amountMinor    Int           @map("amount_minor")
  reference      String?
  idempotencyKey String?       @map("idempotency_key")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, idempotencyKey])
  @@index([orderId])
  @@index([restaurantId, createdAt])
  @@map("payments")
}
