# Copy to .env and fill in. Never commit .env.
NODE_ENV=development
PORT=3001

# Owner role — MIGRATIONS ONLY. On Neon this role has BYPASSRLS, meaning it
# ignores every tenant isolation policy. Never use it for application traffic.
# Copy from the Neon dashboard. Use sslmode=verify-full (authenticates the
# server, not just encrypts) — in production the app refuses to boot without it.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=verify-full"

# Least-privilege runtime role. The app connects as this and is therefore
# actually subject to RLS. Generated by: pnpm --filter @oraos/api db:setup-app-role
# (do not copy the owner URL here — the app refuses to boot if they match)
DATABASE_URL_APP="postgresql://oraos_api:generated@host/dbname?sslmode=verify-full"

# Comma-separated allowlist of browser origins.
CORS_ORIGINS=http://localhost:3000

# Signing key for access tokens. Minimum 32 chars, high entropy, unique per
# environment. Generate with: openssl rand -base64 48
# Rotating this invalidates every access token immediately.
JWT_SECRET=""

# Access tokens cannot be revoked, so this is the blast radius of a stolen one.
JWT_ACCESS_TTL_SECONDS=900

REFRESH_TOKEN_TTL_DAYS=7

# fatal | error | warn | info | debug | trace
LOG_LEVEL=debug

# Reported by GET /health. Set to a release tag or git SHA in the deploy;
# falls back to the package version when unset.
APP_VERSION=

# Base URL of the web app (used to build staff invite and password-reset links).
WEB_URL=http://localhost:3000

# Email (Resend). Leave both blank in local dev/tests: MailService falls back to
# a transport that logs the message instead of sending it. In production set
# both — a key with no MAIL_FROM (or a malformed one) refuses to boot.
#   RESEND_API_KEY: from the Resend dashboard.
#   MAIL_FROM: a verified sender, "Name <addr>" or a bare address.
RESEND_API_KEY=
MAIL_FROM="OraOS <noreply@example.com>"
